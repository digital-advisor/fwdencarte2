rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'celoolarnosol@gmail.com';
    }

    // Admin knowledge-base: only admin can read/write
    match /admin/knowledge-base/{fileName} {
      allow read, write: if isAdmin();
    }

    // Product images uploaded during chat: user can read/write their own
    match /products/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Default: deny all
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
